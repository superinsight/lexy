# Optional: auth credentials for the gateway WebSocket
# OPENCLAW_GATEWAY_TOKEN=your-secret-token
# OPENCLAW_GATEWAY_PASSWORD=your-password

# AI model API key (provide ONE matching your chosen model provider)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AI...

# Default model in "provider/model" format (e.g. openai/gpt-5.4, anthropic/claude-sonnet-4-5)
# LEXY_DEFAULT_MODEL=openai/gpt-5.4

# Port overrides (defaults shown)
# PORTAL_PORT=5174
# GATEWAY_PORT=18789
