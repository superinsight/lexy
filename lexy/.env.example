# Optional: auth credentials for the gateway WebSocket
# OPENCLAW_GATEWAY_TOKEN=your-secret-token
# OPENCLAW_GATEWAY_PASSWORD=your-password

# AI model API key (provide ONE matching your chosen model provider)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AI...

# Default model in "provider/model" format (e.g. openai/gpt-5.4, anthropic/claude-sonnet-4-5)
# LEXY_DEFAULT_MODEL=openai/gpt-5.4

# Proxy mode: route all LLM calls through your own proxy for metering/billing.
# When set, API calls go to LEXY_PROXY_BASE_URL instead of directly to providers.
# Each customer gets a unique LEXY_PROXY_API_KEY that your proxy validates.
# LEXY_PROXY_BASE_URL=https://your-proxy.example.com
# LEXY_PROXY_API_KEY=customer-abc-key-123

# Google OAuth credentials (required for Google Workspace integration token refresh)
# Must match the client ID/secret used in lexy/portal/.env (VITE_GOOGLE_CLIENT_ID/SECRET)
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...

# Port overrides (defaults shown)
# PORTAL_PORT=5174
# GATEWAY_PORT=18789
